{
  "extends": "astro/tsconfigs/base",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "strict": false,
    "skipLibCheck": true
  },
  "include": [
    ".astro/types.d.ts",
    "**/*.astro"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "**/*.js",
    "**/*.mjs",
    "src/**/*.js"
  ]
}
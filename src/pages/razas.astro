---
import Layout from '../layouts/Layout.astro';
// Ahora la ruta de importación es correcta
let razas = [];
let error = null;

try {
  // Usa la URL completa durante el desarrollo
  const baseUrl = Astro.url.origin;
  const apiUrl = `${baseUrl}/api/razas`;
  
  console.log('Fetching desde:', apiUrl);
  
  const res = await fetch(apiUrl, {
    method: 'GET',
    headers: {
      'Content-Type': 'application/json',
    }
  });
  
  console.log('Response status:', res.status);
  console.log('Response headers:', res.headers);
  
  if (!res.ok) {
    throw new Error(`HTTP ${res.status}: ${res.statusText}`);
  }
  
  const contentType = res.headers.get('content-type');
  if (!contentType?.includes('application/json')) {
    const text = await res.text();
    console.log('Response text:', text.substring(0, 200));
    throw new Error(`Respuesta no es JSON. Content-Type: ${contentType}`);
  }
  
  const result = await res.json();
  console.log('API Result:', result);
  
  razas = result.success ? result.data : [];
} catch (e) {
  console.error('Error completo:', e);
  error = e.message;
  razas = [];
}
---
<Layout>
  <body class="bg-gray-100 p-8">
    <h1 class="text-3xl font-bold text-center mb-8">Razas de Perros</h1>

    <section class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
      {razas.map((raza) => (
        <article class="bg-white shadow rounded-lg overflow-hidden">
          <img class="h-48 w-full object-cover" src={raza.img} alt={raza.nombre} />
          <div class="p-4">
            <h2 class="text-xl font-semibold">{raza.nombre}</h2>
            <p class="text-sm text-gray-500">Origen: {raza.origen}</p>
            <p class="mt-2 text-gray-700 text-sm">{raza.historia}</p>
          </div>
        </article>
      ))}
    </section>

    {razas.length === 0 && (
      <p class="text-center text-gray-500">No hay datos en la base de datos todavía.</p>
    )}
  </body>
</Layout>